{
  "name": "@wirdestack/react-filter",
  "version": "3.0.1",
  "description": "A small React attribute filter with typed filter semantics",
  "type": "module",
  "main": "./dist/react-filter.umd.cjs",
  "types": "./dist/src/index.d.ts",
  "module": "./dist/react-filter.js",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/react-filter.js",
      "require": "./dist/react-filter.umd.cjs",
      "default": "./dist/react-filter.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "scripts": {
    "build": "tsc && vite build",
    "build:watch": "vite build --watch && tsc --watch",
    "build-for-test": "npm run build && npm pack && rm ../wirdestack-react-filter-*.tgz && mv ./wirdestack-react-filter-*.tgz ../",
    "lint": "eslint ./src"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wirdehall/react-filter.git"
  },
  "keywords": [
    "react",
    "filter",
    "attribute"
  ],
  "author": "Wirdehall (https://github.com/wirdehall)",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/wirdehall/react-filter/issues"
  },
  "homepage": "https://github.com/wirdehall/react-filter#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.0.8",
    "eslint": "^10.5.0",
    "react": "^19.0.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.2"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "allowScripts": {
    "fsevents@2.3.3": true
  }
}
